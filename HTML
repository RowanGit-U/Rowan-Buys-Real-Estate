<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rowan's Website</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f7f7f7;
      color: #222;
    }
    header {
      background: #111;
      color: white;
      padding: 60px 20px;
      text-align: center;
    }
    section {
      max-width: 900px;
      margin: auto;
      padding: 50px 20px;
    }
    .card {
      background: white;
      padding: 24px;
      border-radius: 14px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.08);
      margin-top: 20px;
    }
    .btn {
      display: inline-block;
      margin-top: 20px;
      padding: 12px 20px;
      background: #111;
      color: white;
      text-decoration: none;
      border-radius: 8px;
    }
    footer {
      text-align: center;
      padding: 30px 20px;
      color: #666;
    }
  </style>
</head>
<body>
  <header>
    <h1>Welcome to My Website</h1>
    <p>Built for free and ready to grow.</p>
  </header>

  <section>
    <div class="card">
      <h2>About Me</h2>
      <p>
        Hi, I’m Rowan. This is my personal website where I can share my work,
        projects, business ideas, and contact information.
      </p>
      <a class="btn" href="mailto:youremail@example.com">Contact Me</a>
    </div>

    <div class="card">
      <h2>Projects</h2>
      <p>Add your portfolio, business, resume, sports work, or real estate work here.</p>
    </div>
  </section>

  <footer>
    © 2026 Rowan. All rights reserved.
  </footer>
</body>
</html>
